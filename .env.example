# Database (port 9370 = Dayton area code 937 + 0)
DATABASE_URL=postgresql+asyncpg://citymap:citymap@localhost:9370/citymap
DATABASE_URL_SYNC=postgresql://citymap:citymap@localhost:9370/citymap

# Martin tile server (port 9371 = 937 + 1)
MARTIN_URL=http://localhost:9371

# MinIO (S3-compatible object storage, ports 9372/9373 = 937 + 2/3)
S3_ENDPOINT_URL=http://localhost:9372
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=citymap-tiles
S3_REGION=us-east-1

# Foursquare API (for POI supplementary import)
FOURSQUARE_API_KEY=your_foursquare_api_key_here

# Pelias geocoder (self-hosted)
PELIAS_URL=http://localhost:4000

# Application (port 9374 = 937 + 4)
APP_ENV=development
APP_PORT=9374
APP_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:9375

# Frontend (Vite, port 9375 = 937 + 5)
VITE_API_URL=http://localhost:9374/api/v1
VITE_MARTIN_URL=http://localhost:9371
VITE_BASEMAP_URL=https://protomaps.github.io/basemaps-assets/v4.bin
