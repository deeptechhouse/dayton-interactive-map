# Database
DATABASE_URL=postgresql+asyncpg://citymap:citymap@localhost:5433/citymap
DATABASE_URL_SYNC=postgresql://citymap:citymap@localhost:5433/citymap

# Martin tile server
MARTIN_URL=http://localhost:3030

# MinIO (S3-compatible object storage)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=citymap-tiles
S3_REGION=us-east-1

# Foursquare API (for POI supplementary import)
FOURSQUARE_API_KEY=your_foursquare_api_key_here

# Pelias geocoder (self-hosted)
PELIAS_URL=http://localhost:4000

# Application
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173

# Frontend (Vite)
VITE_API_URL=http://localhost:8000/api/v1
VITE_MARTIN_URL=http://localhost:3030
VITE_BASEMAP_URL=https://protomaps.github.io/basemaps-assets/v4.bin
